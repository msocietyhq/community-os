{
  "name": "community-os",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,cyan --kill-others-on-fail \"bun run --cwd apps/api dev\" \"wait-on tcp:3000 && bun run --cwd apps/web dev\"",
    "build": "bun run --filter '*' build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "type-check": "bun run --filter '*' type-check",
    "db:generate": "bun run --filter api db:generate",
    "db:migrate": "bun run --filter api db:migrate",
    "db:seed": "bun run --filter api db:seed"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260313.1",
    "bun-types": "^1.3.10",
    "concurrently": "^9.2.1",
    "wait-on": "^9.0.4"
  }
}
