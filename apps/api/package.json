{
  "name": "@community-os/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "./scripts/dev-webhook.sh",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "type-check": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@community-os/shared": "workspace:*",
    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/openapi": "^1.2.0",
    "ai": "^6.0.116",
    "better-auth": "^1.2.0",
    "better-auth-telegram": "^1.5.0",
    "drizzle-orm": "^0.40.0",
    "elysia": "^1.3.0",
    "elysia-rate-limit": "^4.5.1",
    "grammy": "^1.35.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
