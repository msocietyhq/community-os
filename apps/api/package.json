{
  "name": "@community-os/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "type-check": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.0",
    "@elysiajs/openapi": "^1.2.0",
    "better-auth": "^1.2.0",
    "drizzle-orm": "^0.40.0",
    "elysia": "^1.3.0",
    "postgres": "^3.4.0",
    "zod": "^3.24.0",
    "@community-os/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
